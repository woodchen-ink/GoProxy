# Docker 容器配置
CONTAINER_NAME=goproxy

# 端口配置
STABLE_PORT=7776           # HTTP + SOCKS5 最低延迟混合端口
RANDOM_PORT=7777           # HTTP + SOCKS5 随机轮换混合端口
WEBUI_PORT=7778            # WebUI 管理端口

# 地理过滤配置
# 屏蔽指定国家代码的出口代理（逗号分隔，如 CN,RU,KP）
# 留空 = 不屏蔽任何国家
# 默认屏蔽中国大陆（CN），香港（HK）、澳门（MO）、台湾（TW）不受影响
BLOCKED_COUNTRIES=CN

# 代理服务认证配置
# ⚠️ 代理端口默认对外开放，强烈建议启用认证！
# 使用方式：curl -x http://username:password@host:port https://example.com
PROXY_AUTH_ENABLED=false        # 是否启用代理认证（true/false）
PROXY_AUTH_USERNAME=proxy       # 代理认证用户名
PROXY_AUTH_PASSWORD=            # 代理认证密码（留空=不启用认证）
# 示例：PROXY_AUTH_PASSWORD=my_secure_password_123

# SOCKS5 DNS 模式
# remote   = 始终交给上游 SOCKS5 解析域名
# fallback = 先上游解析，失败后再用本机 DNS 解析成 IP 重试
# local    = 始终由 GoProxy 本机先解析域名，再把 IP 发给上游
SOCKS5_DNS_MODE=fallback

# 兼容旧配置（已废弃，优先级低于 SOCKS5_DNS_MODE）
# true  = fallback
# false = remote
# SOCKS5_LOCAL_DNS_FALLBACK=true

# SOCKS5 上游协议策略
# false = 下游 SOCKS5 仅使用上游 SOCKS5
# true  = 下游 SOCKS5 允许复用上游 HTTP 代理（通过 CONNECT 转发）
SOCKS5_ALLOW_HTTP_UPSTREAM=false

# WebUI 认证配置
WEBUI_PASSWORD=goproxy          # ⚠️ 生产环境请修改为强密码

# 数据存储配置
# 容器镜像默认使用 /app/data；本地直接运行默认使用项目 data/ 目录
# 如需自定义位置，可取消注释覆盖
# DATA_DIR=./data

# 时区配置
TZ=Asia/Shanghai
